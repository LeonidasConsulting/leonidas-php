# ── Directory index — PHP takes priority over HTML ────────────────────────────
DirectoryIndex index.php index.html

# ── HTTPS redirect ────────────────────────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{REQUEST_URI} !^/chat/
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── www → non-www ─────────────────────────────────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\.leonidastek\.com [NC]
RewriteCond %{REQUEST_URI} !^/chat/
RewriteRule ^ https://leonidastek.com%{REQUEST_URI} [L,R=301]

# ── Force index.php over index.html at root ───────────────────────────────────
RewriteCond %{THE_REQUEST} \s/index\.html[\s?]
RewriteRule ^ / [R=301,L]
RewriteCond %{DOCUMENT_ROOT}/index.php -f
RewriteRule ^$ index.php [L]

# ── HTML → PHP URL rewrites ────────────────────────────────────────────────────
RewriteRule ^index\.html$ / [R=301,L]
RewriteRule ^about\.html$ /about.php [R=301,L]
RewriteRule ^contact\.html$ /contact.php [R=301,L]
RewriteRule ^privacy-policy\.html$ /privacy-policy.php [R=301,L]
RewriteRule ^terms-and-conditions\.html$ /terms-and-conditions.php [R=301,L]
RewriteRule ^services/managed-it\.html$ /services/managed-it.php [R=301,L]
RewriteRule ^services/cybersecurity\.html$ /services/cybersecurity.php [R=301,L]
RewriteRule ^services/network-engineering\.html$ /services/network-engineering.php [R=301,L]
RewriteRule ^services/unified-communications\.html$ /services/unified-communications.php [R=301,L]
RewriteRule ^services/telecom-wan\.html$ /services/telecom-wan.php [R=301,L]
RewriteRule ^services/desktop-support\.html$ /services/desktop-support.php [R=301,L]
RewriteRule ^industries/healthcare\.html$ /industries/healthcare.php [R=301,L]
RewriteRule ^industries/legal\.html$ /industries/legal.php [R=301,L]
RewriteRule ^industries/construction\.html$ /industries/construction.php [R=301,L]
RewriteRule ^industries/hospitality\.html$ /industries/hospitality.php [R=301,L]
RewriteRule ^industries/government-contractors\.html$ /industries/government-contractors.php [R=301,L]
RewriteRule ^industries/professional-services\.html$ /industries/professional-services.php [R=301,L]
RewriteRule ^blog/index\.html$ /blog/ [R=301,L]
RewriteRule ^blog/post\.html$ /blog/ [R=301,L]

# ── Blog pretty URLs ─────────────────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/([a-z0-9\-]+)/?$ /blog/post.php?slug=$1 [QSA,L]

# ── Sitemap + Feed → dynamic PHP ─────────────────────────────────────────────
RewriteRule ^sitemap\.xml$ /sitemap.php [L]
RewriteRule ^feed\.xml$ /feed.php [L]

# ── Block sensitive paths ─────────────────────────────────────────────────────
RedirectMatch 404 /\.git
RedirectMatch 404 ^/includes/
RedirectMatch 404 ^/lib/
RedirectMatch 404 ^/chat/?$
RedirectMatch 404 ^/config/
RedirectMatch 404 ^/data/

# ── Security headers for static files ────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ── GZip compression ──────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Browser caching ───────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ── Directory listing off ──────────────────────────────────────────────────────
Options -Indexes

# ── Custom error pages ────────────────────────────────────────────────────────
ErrorDocument 404 /404.php
